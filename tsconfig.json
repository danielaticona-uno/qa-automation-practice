{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "outDir": "dist"
  },
  "include": [
    "src/**/*.ts",
    "appium/**/*.ts",
    "tests/**/*.ts",
    "pages/**/*.ts",
    "schemas/**/*.ts",
    "utils/**/*.ts"
  ]
}